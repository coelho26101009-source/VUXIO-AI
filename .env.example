# ═══════════════════════════════════════════════════════════
#  VIMO AI — Variáveis de Ambiente (EXEMPLO)
#
#  1. Copia este ficheiro e renomeia para ".env"
#  2. Preenche com as tuas chaves reais
#  3. NUNCA envies o ".env" para o GitHub!
# ═══════════════════════════════════════════════════════════

# Groq API (https://console.groq.com)
VITE_GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# (Opcional) URL alternativo para a API — usa um proxy próprio (ex.: Cloudflare Worker)
# para esconder a chave no servidor. Se vazio, chama a Groq diretamente.
# VITE_GROQ_API_URL=https://teu-worker.workers.dev/v1/chat/completions

# Firebase (https://console.firebase.google.com)
VITE_FIREBASE_API_KEY=AIzaSy_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=teu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=teu-projeto
VITE_FIREBASE_STORAGE_BUCKET=teu-projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
